# ─────────────────────────────────────────────
# Bookshop.org
# ─────────────────────────────────────────────
# Your affiliate ID (the short code in your affiliate links)
BOOKSHOP_AFFILIATE_ID=your_affiliate_id_here

# ─────────────────────────────────────────────
# Bluesky
# ─────────────────────────────────────────────
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_PASSWORD=your_app_password_here
# Generate an App Password at: Settings > Privacy and Security > App Passwords

# ─────────────────────────────────────────────
# Instagram (via Meta Graph API)
# ─────────────────────────────────────────────
# Requires: Instagram Business or Creator account linked to a Facebook Page
# Get these from: developers.facebook.com > Your App > Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_USER_ID=your_instagram_user_id

# Imgur (used to host images for Instagram — free API key)
# Get one at: api.imgur.com/oauth2/addclient (choose "Anonymous usage without user authorization")
IMGUR_CLIENT_ID=your_imgur_client_id

# ─────────────────────────────────────────────
# TikTok (Content Posting API)
# ─────────────────────────────────────────────
# Requires: TikTok Developer account + app with video.upload scope
# See README for full OAuth setup instructions
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
